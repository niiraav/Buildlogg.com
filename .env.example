VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Entitlements — Stripe Checkout URL for Pro upgrade (placeholder during beta)
VITE_STRIPE_CHECKOUT_URL=https://buy.stripe.com/buildlogg-pro

# Stripe (W2-2: Deposits + Payment Links)
# Create restricted key: Stripe Dashboard → Developers → API Keys → Create restricted key
# Permissions: Checkout Sessions (Write), Webhooks (Read)
STRIPE_SECRET_KEY=sk_live_xxx
# Webhook secret: Stripe Dashboard → Developers → Webhooks → Add endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional: override the site root URL for the booking page link/QR (defaults to window.location.origin)
# VITE_SITE_URL=https://buildlogg.com
